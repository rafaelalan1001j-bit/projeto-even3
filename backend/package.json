{
  "name": "ufra-eventos-backend",
  "version": "1.0.0",
  "description": "Backend da plataforma UFRA Eventos - API RESTful para gerenciamento de eventos acadêmicos",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step required for backend'",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev && node prisma/seed.js",
    "postinstall": "prisma generate"
  },
  "keywords": ["ufra", "eventos", "academico", "nodejs", "express", "prisma"],
  "author": "UFRA Campus Paragominas",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.11",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "sharp": "^0.33.2",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
