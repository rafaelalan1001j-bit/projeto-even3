NODE_ENV=production
PORT=3001
FRONTEND_URL=https://seu-projeto.vercel.app

# Gerado automaticamente pelo Railway ao adicionar PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

JWT_SECRET=troque_por_uma_chave_segura_de_32_caracteres_minimo
JWT_EXPIRES_IN=7d

# Configurar com seu provedor de email (ex: Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
EMAIL_FROM=UFRA Eventos <noreply@ufra.edu.br>

UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
CERTIFICATES_DIR=./certificates
CERT_VALIDATION_URL=https://seu-projeto.vercel.app/certificados/validar

LOG_LEVEL=info
LOG_DIR=./logs
