# ==================================================
# UFRA Eventos - Variáveis de Ambiente (Backend)
# Copie este arquivo para backend/.env
# ==================================================

# Servidor
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://ufra:ufra2024@localhost:5432/ufra_eventos?schema=public"

# Autenticação JWT
JWT_SECRET=ufra_eventos_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=ufra_eventos_refresh_secret_key_change_in_production_2024
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer - usando Ethereal para testes gratuitos)
# Crie uma conta em https://ethereal.email para obter credenciais de teste
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_usuario_ethereal@ethereal.email
SMTP_PASS=sua_senha_ethereal
EMAIL_FROM=UFRA Eventos <noreply@ufra.edu.br>

# Uploads locais
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_DOC_TYPES=application/pdf

# Certificados
CERTIFICATES_DIR=./certificates
CERT_VALIDATION_URL=http://localhost:3000/certificados/validar

# Logs
LOG_LEVEL=debug
LOG_DIR=./logs
